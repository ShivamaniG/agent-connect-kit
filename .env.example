# Agent Connect Kit — copy to .env and fill in real values.

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Fernet key used to encrypt stored OAuth tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET=replace-with-fernet-key

# Static API key required on X-API-Key header for /actions/* and /connections/*.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=replace-with-random-token

# --- Database ---
DATABASE_URL=postgresql+asyncpg://ack:ack@postgres:5432/ack
POSTGRES_USER=ack
POSTGRES_PASSWORD=ack
POSTGRES_DB=ack

# --- GitHub OAuth App ---
# Register at https://github.com/settings/applications/new
# Callback URL must match GITHUB_REDIRECT_URI below.
GITHUB_CLIENT_ID=your-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-oauth-app-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/connections/github/callback
GITHUB_OAUTH_SCOPES=repo,read:org
